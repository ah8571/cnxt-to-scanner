{
  "expo": {
    "name": "cnxt to scanner",
    "slug": "cnxt-to-scanner-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "cnxt-to-scanner",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1117"
    },
    "assetBundlePatterns": ["**/*"],
    "android": {
      "package": "to.cnxt.scanner",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d1117"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "ios": {
      "bundleIdentifier": "to.cnxt.scanner",
      "infoPlist": {
        "NSCameraUsageDescription": "cnxt to scanner uses your camera to scan documents and QR codes.",
        "NSPhotoLibraryUsageDescription": "cnxt to scanner saves scanned documents to your photo library.",
        "NSPhotoLibraryAddUsageDescription": "cnxt to scanner saves scanned documents to your photo library."
      }
    },
    "plugins": [
      "expo-camera",
      "expo-media-library",
      [
        "react-native-document-scanner-plugin",
        {
          "cameraPermission": "Allow cnxt to scanner to use your camera to scan documents."
        }
      ]
    ]
  }
}
